{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Next.js: debug server-side (WSL)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 9229,
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/portfolio-app",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
